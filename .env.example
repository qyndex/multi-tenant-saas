# =============================================================================
# Supabase — required for auth, database, and RLS
# =============================================================================
# Local dev (after `npx supabase start`):
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-local-anon-key"

# Production (from Supabase dashboard → Settings → API):
# NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# =============================================================================
# Prisma — optional, for Prisma-based workflows alongside Supabase
# =============================================================================
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# =============================================================================
# Stripe — billing integration (optional until you enable billing)
# =============================================================================
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
